# AUTOMATED SETUP — `setup.sh`

Replace the current 4-step manual process with a single interactive script.

## What the script does

1. Creates virtualenv if missing, installs requirements
2. Asks every config question interactively (with sensible defaults shown)
3. Writes `config/secrets.py`, `config/personals.py`, `config/questions.py`, `config/answers.py` from answers
4. Verifies resume file exists
5. Runs `--validate-config` and prints a pass/fail summary

---

## `setup.sh` — full script

```bash
#!/usr/bin/env bash
set -e

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$REPO_ROOT"

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
info()    { echo -e "${GREEN}✔  $*${NC}"; }
prompt()  { echo -e "${YELLOW}▶  $*${NC}"; }
warn()    { echo -e "${RED}✗  $*${NC}"; }

ask() {
    # ask <varname> <question> [default]
    local varname="$1" question="$2" default="$3"
    if [ -n "$default" ]; then
        read -rp "$(echo -e "${YELLOW}  ${question} [${default}]: ${NC}")" value
        value="${value:-$default}"
    else
        read -rp "$(echo -e "${YELLOW}  ${question}: ${NC}")" value
        while [ -z "$value" ]; do
            warn "  This field is required."
            read -rp "$(echo -e "${YELLOW}  ${question}: ${NC}")" value
        done
    fi
    printf -v "$varname" '%s' "$value"
}

ask_secret() {
    # ask_secret <varname> <question>
    local varname="$1" question="$2" value
    read -rsp "$(echo -e "${YELLOW}  ${question} (hidden): ${NC}")" value
    echo
    printf -v "$varname" '%s' "$value"
}

echo ""
echo "╔══════════════════════════════════════════════╗"
echo "║     LinkedIn AutoApply Bot — First-Time Setup ║"
echo "╚══════════════════════════════════════════════╝"
echo ""

# ── 1. Python / venv ────────────────────────────────────────────────────────
prompt "Step 1/6 — Setting up Python environment"
if [ ! -d "venv" ]; then
    python3 -m venv venv
    info "Created virtualenv"
else
    info "Virtualenv already exists"
fi
source venv/bin/activate
pip install --quiet --upgrade pip
pip install --quiet -r requirements.txt
info "Dependencies installed"

# ── 2. LinkedIn credentials ─────────────────────────────────────────────────
echo ""
prompt "Step 2/6 — LinkedIn credentials"
ask        LI_EMAIL    "LinkedIn email address"
ask_secret LI_PASSWORD "LinkedIn password"

AI_CHOICE=""
while [[ "$AI_CHOICE" != "1" && "$AI_CHOICE" != "2" && "$AI_CHOICE" != "3" ]]; do
    ask AI_CHOICE "AI provider? [1] OpenAI  [2] Google Gemini  [3] None (offline mode)" "1"
done

AI_KEY=""
if [ "$AI_CHOICE" = "1" ]; then
    ask_secret AI_KEY "OpenAI API key (sk-...)"
    AI_SECRETS="openai_api_key = \"$AI_KEY\"\ngemini_api_key = \"\""
elif [ "$AI_CHOICE" = "2" ]; then
    ask_secret AI_KEY "Gemini API key"
    AI_SECRETS="openai_api_key = \"\"\ngemini_api_key = \"$AI_KEY\""
else
    AI_SECRETS="openai_api_key = \"\"\ngemini_api_key = \"\""
fi

cat > config/secrets.py << PYEOF
# Auto-generated by setup.sh — do not commit
linkedin_email    = "$LI_EMAIL"
linkedin_password = "$LI_PASSWORD"
$(echo -e "$AI_SECRETS")
PYEOF
info "config/secrets.py written"

# ── 3. Personal info ─────────────────────────────────────────────────────────
echo ""
prompt "Step 3/6 — Personal information (used to fill forms)"
ask FIRST_NAME   "First name"
ask LAST_NAME    "Last name"
ask PHONE        "Phone number (with country code, e.g. +1-555-123-4567)"
ask CITY         "City"
ask STATE        "State / Province"
ask COUNTRY      "Country" "United States"
ask LINKEDIN_URL "LinkedIn profile URL" "https://www.linkedin.com/in/yourprofile"
ask WEBSITE      "Personal website / portfolio URL (leave blank to skip)" ""

cat > config/personals.py << PYEOF
# Auto-generated by setup.sh
first_name  = "$FIRST_NAME"
last_name   = "$LAST_NAME"
phone       = "$PHONE"
city        = "$CITY"
state       = "$STATE"
country     = "$COUNTRY"
linkedin    = "$LINKEDIN_URL"
website     = "$WEBSITE"
# EEO fields — leave blank to decline
ethnicity         = ""
gender            = ""
disability_status = ""
veteran_status    = ""
PYEOF
info "config/personals.py written"

# ── 4. Resume & experience ───────────────────────────────────────────────────
echo ""
prompt "Step 4/6 — Resume and experience"
ask RESUME_PATH "Path to your resume PDF" "$REPO_ROOT/resume.pdf"

# Resolve relative paths
if [[ "$RESUME_PATH" != /* ]]; then
    RESUME_PATH="$REPO_ROOT/$RESUME_PATH"
fi

if [ ! -f "$RESUME_PATH" ]; then
    warn "Resume not found at '$RESUME_PATH'. You must place it there before running the bot."
else
    info "Resume found: $RESUME_PATH"
fi

ask YEARS_EXP   "Total years of software experience" "5"
ask DESIRED_SAL "Desired annual salary (number only, USD)" "120000"
ask NOTICE      "Notice period in days" "30"
ask AUTH_WORK   "Authorized to work without sponsorship? (Yes/No)" "Yes"
ask VISA        "Do you require visa sponsorship? (Yes/No)" "No"
ask RELOCATE    "Willing to relocate? (Yes/No)" "No"
ask WORK_MODE   "Preferred work mode (Remote/Hybrid/On-site)" "Remote"

cat > config/questions.py << PYEOF
# Auto-generated by setup.sh
default_resume_path = "$RESUME_PATH"
years_of_experience = "$YEARS_EXP"
linkedin            = "$LINKEDIN_URL"
website             = "$WEBSITE"
PYEOF

cat > config/answers.py << PYEOF
# Auto-generated by setup.sh
desired_salary          = $DESIRED_SAL
current_ctc             = 0
notice_period           = $NOTICE
require_visa            = "$VISA"
authorized_to_work      = "$AUTH_WORK"
willing_to_relocate     = "$RELOCATE"
preferred_work_mode     = "$WORK_MODE"
start_date_days_notice  = $NOTICE
felony_conviction       = "No"
us_citizenship          = "Other"
ethnicity               = ""
gender                  = ""
disability_status       = ""
veteran_status          = ""
cover_letter            = ""
confidence_level        = "8"
skill_experience        = {}  # Add per-skill: {"Python": "8", "React": "3"}
PYEOF
info "config/questions.py and config/answers.py written"

# ── 5. Job search preferences ────────────────────────────────────────────────
echo ""
prompt "Step 5/6 — Job search preferences"
ask JOB_TITLE   "Job title to search (e.g. 'Software Engineer')" "Software Engineer"
ask JOB_LOCATION "Location (e.g. 'San Francisco, CA' or 'Remote')" "Remote"
ask MAX_JOBS    "Maximum applications per session" "10"

# Append search config (search.py already exists as template)
if [ ! -f "config/search.py" ]; then
    cp config/search.example.py config/search.py 2>/dev/null || true
fi

# Patch the key fields inline
python3 - << PYEOF
import re, pathlib
path = pathlib.Path("config/search.py")
text = path.read_text()
text = re.sub(r'job_titles\s*=\s*\[.*?\]', 'job_titles = ["$JOB_TITLE"]', text, flags=re.S)
text = re.sub(r'location\s*=\s*"[^"]*"', 'location = "$JOB_LOCATION"', text)
path.write_text(text)
PYEOF
info "config/search.py updated"

# Patch max_applied_jobs in settings.py
python3 - << PYEOF
import re, pathlib
path = pathlib.Path("config/settings.py")
text = path.read_text()
text = re.sub(r'max_applied_jobs\s*=\s*\d+', 'max_applied_jobs = $MAX_JOBS', text)
path.write_text(text)
PYEOF
info "config/settings.py updated (max_applied_jobs = $MAX_JOBS)"

# ── 6. Validate and summarise ────────────────────────────────────────────────
echo ""
prompt "Step 6/6 — Validating configuration"
if python runAiBot.py --validate-config 2>&1; then
    info "Configuration valid ✔"
else
    warn "Validation found issues — check output above and re-run setup.sh or edit config files manually"
fi

echo ""
echo "╔══════════════════════════════════════════════╗"
echo "║               Setup complete!                ║"
echo "╚══════════════════════════════════════════════╝"
echo ""
echo "  Files written:"
echo "    config/secrets.py    ← LinkedIn + AI credentials"
echo "    config/personals.py  ← Name, phone, address"
echo "    config/questions.py  ← Resume path, LinkedIn URL"
echo "    config/answers.py    ← Salary, visa, relocation"
echo "    config/search.py     ← Job title, location"
echo ""
echo "  To run the bot:"
echo "    source venv/bin/activate"
echo "    python runAiBot.py"
echo ""
echo "  To preview without applying (dry-run):"
echo "    python runAiBot.py --dry-run"
echo ""
```

